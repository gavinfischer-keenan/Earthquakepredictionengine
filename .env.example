# =============================================================================
# EarthquakePredictionEngine — Configuration
# Copy this file to .env and edit to match your Raspberry Shake setup.
# =============================================================================

# ---------------------------------------------------------------------------
# Raspberry Shake RS4D Connection
# ---------------------------------------------------------------------------
# Hostname or IP of your Raspberry Shake device
SHAKE_IP=192.168.4.164
# Station code (printed on your Shake, e.g. R1A3D)
SHAKE_STATION=R1A3D
# FDSN network code (AM = Raspberry Shake citizen network)
SHAKE_NETWORK=AM
# Primary channel to monitor (EHZ=vertical geophone)
SHAKE_CHANNEL=EHZ
# All RS4D channels (comma-separated)
SHAKE_CHANNELS=EHZ,ENZ,ENN,ENE

# ---------------------------------------------------------------------------
# Station Location (used for distance/magnitude calculations)
# ---------------------------------------------------------------------------
STATION_LAT=37.8696
STATION_LON=-122.2491
STATION_ELEVATION=161.1

# ---------------------------------------------------------------------------
# Data Ingestion
# ---------------------------------------------------------------------------
# Ingest mode: "seedlink" (preferred, TCP) or "udp" (raw packets)
INGEST_MODE=seedlink
# UDP port for raw Shake data (only used when INGEST_MODE=udp)
UDP_PORT=8888
# SeedLink server port on the Shake
SEEDLINK_PORT=18000

# ---------------------------------------------------------------------------
# STA/LTA Trigger Parameters
# ---------------------------------------------------------------------------
# Short-Term Average window in seconds
STA_SECONDS=0.5
# Long-Term Average window in seconds
LTA_SECONDS=20.0
# STA/LTA ratio to trigger ON (declare potential event)
TRIGGER_ON=4.0
# STA/LTA ratio to trigger OFF (end of event)
TRIGGER_OFF=1.5

# ---------------------------------------------------------------------------
# Bandpass Filter
# ---------------------------------------------------------------------------
# Lower corner frequency (Hz) for Butterworth bandpass
BANDPASS_LOW=1.0
# Upper corner frequency (Hz) for Butterworth bandpass
BANDPASS_HIGH=10.0

# ---------------------------------------------------------------------------
# Event Validation
# ---------------------------------------------------------------------------
# Minimum trigger duration to accept an event (rejects spikes)
MIN_TRIGGER_DURATION_SEC=0.5
# Predominant-period (Pd) measurement window after P-arrival (seconds)
PD_WINDOW_SEC=3.0
# Tau-c (period parameter) measurement window after P-arrival (seconds)
TC_WINDOW_SEC=3.0

# ---------------------------------------------------------------------------
# Machine Learning (optional — requires [ml] extras)
# ---------------------------------------------------------------------------
# Enable ML-based phase picking (requires seisbench + torch)
ML_ENABLED=false
# P-wave detection probability threshold (0.0–1.0)
ML_P_THRESHOLD=0.3
# SeisBench model name: phasenet, eqtransformer, etc.
ML_MODEL=phasenet

# ---------------------------------------------------------------------------
# Alerting & Dashboard
# ---------------------------------------------------------------------------
# HTTP endpoint for Berkeley-style dashboard ingestion
DASHBOARD_URL=http://localhost:5050/api/ingest/earthquake-engine
# Minimum seconds between successive alerts (prevents flooding)
ALERT_COOLDOWN_SEC=30

# ---------------------------------------------------------------------------
# Telemetry & Health
# ---------------------------------------------------------------------------
# Interval for heartbeat/status messages (seconds)
HEARTBEAT_INTERVAL_SEC=60

# ---------------------------------------------------------------------------
# Data Buffer
# ---------------------------------------------------------------------------
# Rolling waveform buffer length in seconds
BUFFER_DURATION_SEC=120
# Sampling rate of the RS4D (Hz) — do not change unless hardware differs
SAMPLING_RATE=100

# ---------------------------------------------------------------------------
# Logging & Storage
# ---------------------------------------------------------------------------
# Minimum log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Directory for per-event miniSEED and metadata logs
EVENT_LOG_DIR=./events
